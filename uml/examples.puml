'  +void persist()
'}
'
'

class MyClass
abstract class MyAbstract
interface MyInterface
enum MyEnum
annotation MyAnnotation
entity MyEntity

@enduml

@startuml packages

left to right direction

'packages are used to group related classes together, providing a way to
'organize and modularize the design. They can represent different layers of an
'application (e.g., controller, service, repository) or different functional
'areas (e.g., user management, product management).
'
package "controller" {
  class UserController
  class ProductController
}

package "producer-consumer" {
   class Producer
   class Consumer
}


@enduml
